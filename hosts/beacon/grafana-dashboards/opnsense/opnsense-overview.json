      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{job=\"opnsense-node-exporter\",host=\"opnsense\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU busy",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"opnsense-node-exporter\",host=\"opnsense\"} / node_memory_MemTotal_bytes{job=\"opnsense-node-exporter\",host=\"opnsense\"}))",
          "legendFormat": "Memory used",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Host Utilization",
      "type": "timeseries"
    },
