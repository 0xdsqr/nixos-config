      "id": 1,
      "options": {
        "content": "<div style=\"line-height:1.5;\"><strong>Core host view</strong><br/>This replaces the empty Proxmox host page for now. It tracks one Linux host at a time with Prometheus and Loki, which gives you real CPU, memory, disk, network, and log signal while we wait to wire in native <code>pve_*</code> exporter metrics.</div>",
        "mode": "markdown"
      },
      "title": "About",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "Down"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "Up"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 3
