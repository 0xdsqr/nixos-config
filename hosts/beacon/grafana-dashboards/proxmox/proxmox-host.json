  "description": "Focused view of the Proxmox host. This dashboard assumes Prometheus is receiving pve_* metrics from prometheus-pve-exporter.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "content": "<div style=\"line-height:1.5;\"><strong>Design note</strong><br/>This dashboard is built around <code>pve_*</code> metrics from <code>prometheus-pve-exporter</code>. Once Beacon scrapes that exporter, these panels become the dedicated wallboard for the Dell R730xd / Proxmox host.</div>",
        "mode": "markdown"
      },
      "title": "About",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "Down"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "Up"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 3
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "max(pve_up{id=~\"node/$node\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Node Status",
      "type": "stat"
    },
    {
