{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Guest-centric Proxmox dashboard for VMs and LXCs. Built for prometheus-pve-exporter metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(pve_up{id=~\"qemu/.+\"} * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=\"qemu\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Running VMs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(pve_up{id=~\"lxc/.+\"} * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=\"lxc\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Running LXCs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "count(pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total Guests",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "count(((pve_up{id=~\"(qemu|lxc)/.+\"} == 0) * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"}) > 0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Guests Down",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "displayMode": "gradient",
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "topk(10, 100 * (pve_cpu_usage_ratio{id=~\"(qemu|lxc)/.+\"} * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"}))",
          "instant": true,
          "legendFormat": "{{name}} ({{type}})",
          "refId": "A"
        }
      ],
      "title": "Top CPU Guests",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "id": 6,
      "options": {
        "displayMode": "gradient",
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "topk(10, 100 * ((pve_memory_usage_bytes{id=~\"(qemu|lxc)/.+\"} / clamp_min(pve_memory_size_bytes{id=~\"(qemu|lxc)/.+\"}, 1)) * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"}))",
          "instant": true,
          "legendFormat": "{{name}} ({{type}})",
          "refId": "A"
        }
      ],
      "title": "Top Memory Guests",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "topk(8, rate(pve_disk_written_bytes_total{id=~\"(qemu|lxc)/.+\"}[5m]) * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"})",
          "legendFormat": "{{name}} write",
          "range": true,
          "refId": "A"
        },
        {
          "expr": "topk(8, rate(pve_disk_read_bytes_total{id=~\"(qemu|lxc)/.+\"}[5m]) * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"})",
          "legendFormat": "{{name}} read",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Disk IO by Guest",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "topk(12, pve_uptime_seconds{id=~\"(qemu|lxc)/.+\"} * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"})",
          "legendFormat": "{{name}} ({{type}})",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Guest Uptime",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "Down"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "Up"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 9,
      "options": {
        "displayMode": "gradient",
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "expr": "sort_desc((pve_up{id=~\"(qemu|lxc)/.+\"} * on(id) group_left(name,node,type) pve_guest_info{node=~\"$node\", type=~\"qemu|lxc\"}))",
          "instant": true,
          "legendFormat": "{{name}} ({{type}})",
          "refId": "A"
        }
      ],
      "title": "Current Guest Status",
      "type": "bargauge"
    }
  ],
